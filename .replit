modules = ["python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["alsa-lib", "atk", "cairo", "cups", "dbus", "expat", "geckodriver", "gitFull", "glib", "libdrm", "libgbm", "libxkbcommon", "mesa", "nspr", "nss", "pango", "playwright-driver", "wayland", "xorg.libX11", "xorg.libXau", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libXt", "xorg.libxcb", "xorg.libxshmfence"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Bot"

[[workflows.workflow]]
name = "Run Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"

[workflows.workflow.metadata]
outputType = "console"
